generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Olt {
  id          Int       @id @default(autoincrement())
  name        String
  ip          String    @unique
  port        Int       @default(23)
  protocol    String    @default("telnet") // telnet | ssh
  username    String
  passwordEnc String // AES-256-GCM encrypted, see @oltflow/core crypto
  enablePasswordEnc String? // AES-256-GCM encrypted privileged/enable password (null = use login password)
  location    String?
  vendor      String    @default("zte")
  model       String? // C300 | C320
  slots       Int[]     @default([4, 15, 17, 19, 20]) // GPON board slots
  eponSlots   Int[]     @default([]) // EPON board slots (ETTO/ETTOK cards) — empty if none, e.g. pure-GPON OLTs
  snmpCommunity String? @default("public")
  snmpVersion   String? @default("2c") // 2c | v3 (v3 not implemented yet)
  snmpPort      Int     @default(161)
  latitude    Float?    // geolocation for the network map (ODN / premium)
  longitude   Float?
  status      String    @default("unknown") // online | offline | unknown
  lastSync    DateTime?
  onus        Onu[]
  uncfgOnus   UncfgOnu[]
  jobs        Job[]
  auditLogs   AuditLog[]
  ponTraffic  PonTraffic[]
  health      OltHealth[]
  users       User[]    @relation("UserOlts") // support/viewer scoping (empty = all; admin ignores)
  tickets     Ticket[]
  splitters   Splitter[]
  fiberSegments FiberSegment[]
  alarms      Alarm[]
  maintenanceWindows MaintenanceWindow[]
  createdAt   DateTime  @default(now())
}

/// A PON splitter node in the ODN (fiber distribution). Splitters cascade (primary →
/// secondary) via parentSplitterId; a top-level one hangs off an OLT PON port. Powers the
/// network-map topology and (later) blast-radius fault isolation.
model Splitter {
  id               Int        @id @default(autoincrement())
  name             String
  ratio            String     @default("1:8") // 1:2 | 1:4 | 1:8 | 1:16 | 1:32 | 1:64
  latitude         Float
  longitude        Float
  oltId            Int?
  olt              Olt?       @relation(fields: [oltId], references: [id], onDelete: SetNull)
  ponPort          String?    // OLT PON port it feeds from, e.g. gpon-olt_1/1/1 (for top-level)
  parentSplitterId Int?
  parent           Splitter?  @relation("SplitterTree", fields: [parentSplitterId], references: [id], onDelete: SetNull)
  children         Splitter[] @relation("SplitterTree")
  onus             Onu[]
  note             String?
  createdAt        DateTime   @default(now())

  @@index([oltId])
}

/// A fiber run drawn on the map: backbone / distribution / drop. `path` is the route as an
/// array of [lat,lng] points. Kept geometry-only (not FK-linked to endpoints) so the plant
/// can be sketched fast; nodes (OLT/splitter/ONU) are matched visually by proximity.
model FiberSegment {
  id        Int      @id @default(autoincrement())
  name      String?
  kind      String   @default("distribution") // backbone | distribution | drop
  path      Json     // [[lat,lng], ...]
  oltId     Int?
  olt       Olt?     @relation(fields: [oltId], references: [id], onDelete: SetNull)
  cores     Int?
  lengthM   Int?     // route length in meters (computed client-side or manual)
  createdAt DateTime @default(now())

  @@index([oltId])
}

/// Unconfigured (waiting-authorization) ONUs, persisted from each inventory sync so the
/// dashboard/Unconfigured page read a stable DB row instead of a live `show gpon onu uncfg`
/// per page-load. Reconciled every sync tick: present serials are upserted, absent ones
/// removed — so the "waiting authorization" count is always accurate without a Scan button.
model UncfgOnu {
  id        Int      @id @default(autoincrement())
  oltId     Int
  olt       Olt      @relation(fields: [oltId], references: [id], onDelete: Cascade)
  ponPort   String // gpon-olt_1/15/1 (the PON it was detected on)
  serial    String // ONU serial broadcast before authorization
  state     String? // raw uncfg state, e.g. "unknown"
  firstSeen DateTime @default(now())
  lastSeen  DateTime @default(now())

  @@unique([oltId, serial])
  @@index([oltId])
}

model Onu {
  id             Int       @id @default(autoincrement())
  oltId          Int
  olt            Olt       @relation(fields: [oltId], references: [id], onDelete: Cascade)
  ponPort        String // gpon-onu_1/15/1:1
  serial         String?
  name           String?
  type           String?
  state          String? // working | fail | offline ...
  distance       String?
  onlineDuration String?
  vlan           String?
  pppoeUser      String?
  lineProfile    String?
  serviceProfile String?
  mac            String? // MAC learned on the bridge port (the downstream Mikrotik) — RADIUS join key
  mgmtIp         String? // live device IP (route ONU / bridge Mikrotik), filled from RADIUS by the worker
  expiration     DateTime? // client account expiry from RADIUS Manager (rm_users), filled by the worker
  latitude       Float? // customer/ONU geolocation for the network map (set at install or manually)
  longitude      Float?
  splitterId     Int? // ODN: which splitter port feeds this ONU (for topology + fault isolation)
  splitter       Splitter? @relation(fields: [splitterId], references: [id], onDelete: SetNull)
  lastSeen       DateTime?
  /// Denormalized latest optical reading — written with every Signal insert so fleet
  /// alarm ticks and signal-band filters can use indexed columns instead of DISTINCT ON
  /// over the whole Signal history (critical at 50k–100k ONUs).
  lastOnuRx       Float?
  lastSignalLevel String? // good | warning | critical
  lastSignalAt    DateTime?
  signals        Signal[]
  tickets        Ticket[]
  alarms         Alarm[]
  acsDevice      AcsDevice?

  @@unique([oltId, ponPort])
  @@index([serial])
  @@index([state])
  @@index([oltId, state]) // dashboard/list rollups: count + groupBy ONUs per OLT by state
  @@index([name])
  @@index([pppoeUser])
  @@index([mgmtIp])
  @@index([lastOnuRx])
  @@index([lastSignalLevel])
}

/// GenieACS CPE mirror — pages read this instead of hammering the NBI on every load.
/// Joined to Onu by serial when possible; deviceId is the GenieACS `_id`.
model AcsDevice {
  id               Int       @id @default(autoincrement())
  deviceId         String    @unique // GenieACS _id
  serial           String?
  onuId            Int?      @unique
  onu              Onu?      @relation(fields: [onuId], references: [id], onDelete: SetNull)
  productClass     String?
  modelName        String?
  hardwareVersion  String?
  softwareVersion  String?
  wanIp            String?
  wanMode          String? // PPPoE | DHCP | Static | unknown
  uptimeSec        Int?
  ssid2g           String?
  ssid5g           String?
  wifiEnabled2g    Boolean?
  wifiEnabled5g    Boolean?
  /// [{ hostname, mac, ip, active }]
  lanHosts         Json?
  lastInform       DateTime?
  lastBootstrap    DateTime?
  registered       Boolean   @default(true)
  mirroredAt       DateTime  @default(now())
  /// When provision expected this serial to appear in ACS (handshake check).
  expectedBy       DateTime?

  @@index([serial])
  @@index([softwareVersion])
  @@index([lastInform])
  @@index([mirroredAt])
  @@index([wanIp])
}

model Signal {
  id          BigInt   @id @default(autoincrement())
  onuId       Int
  onu         Onu      @relation(fields: [onuId], references: [id], onDelete: Cascade)
  oltRx       Float?
  onuRx       Float?
  oltTx       Float?
  onuTx       Float?
  attenUp     Float?
  attenDown   Float?
  signalLevel String? // good | warning | critical
  recordedAt  DateTime @default(now())

  @@index([onuId, recordedAt])
  @@index([signalLevel, recordedAt]) // dashboard stats: recent warning/critical signals per OLT
}

/// Per-PON-port throughput samples derived from SNMP 32-bit ifInOctets/ifOutOctets
/// (this ZTE firmware leaves the 64-bit HC counters empty). One row per port per poll;
/// the worker computes bps from the octet delta between polls and prunes rows >24h.
/// downBps = traffic to subscribers (PON ifOutOctets), upBps = from subscribers (ifInOctets).
model PonTraffic {
  id         BigInt   @id @default(autoincrement())
  oltId      Int
  olt        Olt      @relation(fields: [oltId], references: [id], onDelete: Cascade)
  ponPort    String // ifName, e.g. gpon_1/15/6
  downBps    Float
  upBps      Float
  recordedAt DateTime @default(now())

  @@index([oltId, recordedAt])
  @@index([oltId, ponPort, recordedAt])
}

/// Per-card CPU% and temperature snapshots polled from the OLT over SNMP (see
/// getOltHealth in @oltflow/adapters). One row per card per poll; the worker keeps ~24h
/// so the dashboard can draw a short CPU/temp trend. Prunes itself in olt-health.ts.
model OltHealth {
  id         BigInt   @id @default(autoincrement())
  oltId      Int
  olt        Olt      @relation(fields: [oltId], references: [id], onDelete: Cascade)
  slot       Int // physical card slot
  card       String // card model name, e.g. GTGHG
  cpu        Float // percent 0-100
  temp       Float // Celsius
  recordedAt DateTime @default(now())

  @@index([oltId, recordedAt])
  @@index([oltId, slot, recordedAt])
}

model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  name      String?
  passwordH String
  role      String   @default("operator") // admin | support | technician | viewer
  /// Account lifecycle: pending (self-signup awaiting admin) | active | disabled.
  status    String   @default("active") // pending | active | disabled
  emailVerifiedAt DateTime?
  /// OLTs this user may see/operate. Empty = all (backward compatible, unrestricted);
  /// admins are never scoped. Assign specific OLTs to restrict support to their zone.
  olts      Olt[]    @relation("UserOlts")
  /// Telegram chat id for direct ticket notifications (the "ring" to a technician).
  telegramChatId  String?
  openedTickets   Ticket[] @relation("TicketOpenedBy")
  assignedTickets Ticket[] @relation("TicketAssignedTo")
  sessions        Session[]
  settingsUpdated Setting[] @relation("SettingUpdatedBy")
  alarmsAcked     Alarm[]   @relation("AlarmAckedBy")
  permissions     UserPermission[]
  verificationTokens VerificationToken[]
  createdAt DateTime @default(now())

  @@index([status])
}

/// One-time tokens for email verify / password reset / admin invite. Token stored hashed.
model VerificationToken {
  id        String    @id // random uuid
  userId    Int
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  kind      String // verify | reset | invite
  tokenHash String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([tokenHash])
  @@index([userId, kind])
}

/// Seeded catalogue of granular capabilities (onu.reboot, users.manage, …).
/// Role defaults live in code (@oltflow/core); per-user grants/denies are UserPermission rows.
model Permission {
  id          String @id // e.g. "onu.reboot"
  label       String
  description String?
  group       String // onu | olt | tickets | map | admin | system
}

/// Per-user override of a permission. `allow=true` grants even if the role lacks it;
/// `allow=false` denies even if the role has it. Admins always pass authorize().
model UserPermission {
  userId Int
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  perm   String // Permission.id
  allow  Boolean

  @@id([userId, perm])
  @@index([perm])
}

/// Browser/API session (DB-backed). The signed cookie carries the session id as JWT `jti`;
/// revocation and "active sessions" admin views read this table. ExpiresAt mirrors the
/// cookie TTL; lastSeenAt is throttled so busy dashboards don't hammer the row every poll.
model Session {
  id         String    @id // random uuid — JWT jti
  userId     Int
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  ip         String?
  userAgent  String?
  createdAt  DateTime  @default(now())
  lastSeenAt DateTime  @default(now())
  expiresAt  DateTime
  revokedAt  DateTime?

  @@index([userId, revokedAt])
  @@index([expiresAt])
}

/// Runtime-configurable knobs (signal thresholds, sync intervals, retention, locale…).
/// Seeded with defaults from @oltflow/core; admin UI (Phase 2) edits them; worker/web
/// hot-reload via a short-lived in-process cache. Bootstrap secrets stay in .env.
model Setting {
  key         String   @id
  value       Json
  updatedById Int?
  updatedBy   User?    @relation("SettingUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)
  updatedAt   DateTime @updatedAt
}

/// Persisted NOC alarm. The worker opens/clears rows each tick; /api/alarms is a cheap
/// indexed read (no fleet scan). `key` is the stable open-alarm identity used for upsert
/// (e.g. "onu.offline:123", "olt.unreachable:5", "pon.outage:5:gpon-olt_1/1/1").
model Alarm {
  id            BigInt    @id @default(autoincrement())
  key           String    @unique
  type          String // onu.offline | onu.signal.warning | onu.signal.danger | onu.expiry | olt.unreachable | pon.outage
  severity      String // critical | warning
  oltId         Int?
  olt           Olt?      @relation(fields: [oltId], references: [id], onDelete: Cascade)
  onuId         Int?
  onu           Onu?      @relation(fields: [onuId], references: [id], onDelete: Cascade)
  title         String
  detail        String?
  href          String?
  openedAt      DateTime  @default(now())
  clearedAt     DateTime?
  lastSeenAt    DateTime  @default(now())
  ackedById     Int?
  ackedBy       User?     @relation("AlarmAckedBy", fields: [ackedById], references: [id], onDelete: SetNull)
  ackedAt       DateTime?
  silencedUntil DateTime?
  detailJson    Json?

  @@index([clearedAt, severity])
  @@index([type, clearedAt])
  @@index([oltId, clearedAt])
  @@index([onuId, clearedAt])
  @@index([openedAt])
}

/// External integration config (Telegram, SMTP, GenieACS, …). Secrets live in
/// `configEnc` (AES-GCM JSON via OLT_CRED_KEY). Env vars remain bootstrap fallback.
model Integration {
  id           String    @id // telegram | whatsapp | smtp | webhook | genieacs | radius | winbox
  enabled      Boolean   @default(false)
  configEnc    String? // AES-GCM encrypted JSON blob
  status       String? // ok | error | unconfigured | unknown
  statusDetail String?
  lastCheckAt  DateTime?
  updatedAt    DateTime  @updatedAt
  updatedById  Int?
}

/// Admin-editable notification rule: event type × severity × scope × channel(s) × behavior.
/// Seeded with today's Telegram alarm behaviour so nothing regresses on upgrade.
model NotificationRule {
  id               Int      @id @default(autoincrement())
  name             String
  eventType        String // onu.offline | onu.signal.warning | onu.signal.danger | onu.expiry | olt.unreachable | pon.outage | ...
  severityMin      String? // warning | critical | null = any
  enabled          Boolean  @default(true)
  scopeAll         Boolean  @default(true) // false → only oltIds
  oltIds           Int[]    @default([])
  /// [{ "type": "telegram", "chatId"?: "..." }, { "type": "smtp", "to": ["a@b.c"] }, { "type": "webhook" }, { "type": "whatsapp", "to": "+355..." }]
  channels         Json
  behavior         String   @default("once_until_clear") // once_until_clear | daily | every
  quietStart       String? // "HH:MM" local (Europe/Tirane-ish; wall clock on server)
  quietEnd         String?
  escalateAfterMin Int?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([eventType, enabled])
}

/// Every delivery attempt — "did the alert go out?" is answerable from admin.
model NotificationLog {
  id        BigInt   @id @default(autoincrement())
  ruleId    Int?
  eventType String
  channel   String // telegram | smtp | webhook | whatsapp
  status    String // sent | failed | skipped
  error     String?
  target    String? // chat id / email / webhook url (no secrets)
  detail    Json?
  alarmKey  String?
  oltId     Int?
  onuId     Int?
  createdAt DateTime @default(now())

  @@index([createdAt])
  @@index([eventType, createdAt])
  @@index([status, createdAt])
  @@index([alarmKey, createdAt])
}

/// Suppress alarms/notifications for a scheduled window (per OLT or fleet-wide).
model MaintenanceWindow {
  id          Int      @id @default(autoincrement())
  name        String
  oltId       Int? // null = all OLTs
  olt         Olt?     @relation(fields: [oltId], references: [id], onDelete: Cascade)
  startsAt    DateTime
  endsAt      DateTime
  reason      String?
  createdById Int?
  createdAt   DateTime @default(now())

  @@index([startsAt, endsAt])
  @@index([oltId, startsAt])
}

/// Where backups are written: local volume and/or SSH/SFTP off-site.
/// configEnc holds AES-GCM JSON (path, host, port, user, key/password, remotePath).
model BackupTarget {
  id         Int      @id @default(autoincrement())
  kind       String // local | ssh
  name       String
  configEnc  String // encrypted JSON
  /// Simple schedule: "" = manual only; "daily:03:00"; "weekly:sun:03:00"
  schedule   String?
  /// { "keepLast": 7, "keepWeekly": 4 }
  retention  Json?
  enabled    Boolean  @default(true)
  lastRunAt  DateTime?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  runs       BackupRun[]
}

/// One backup execution (manual or scheduled). Artifacts live on disk / remote;
/// this row is the index for admin UI + restore commands.
model BackupRun {
  id         Int       @id @default(autoincrement())
  targetId   Int?
  target     BackupTarget? @relation(fields: [targetId], references: [id], onDelete: SetNull)
  status     String    @default("queued") // queued | running | success | failed | verified
  /// Relative path under BACKUP_DIR, e.g. runs/2026-07-09T12-00-00Z
  path       String?
  sizeBytes  BigInt?
  sha256     String?
  manifest   Json?
  startedAt  DateTime  @default(now())
  finishedAt DateTime?
  error      String?
  log        String? // truncated run log
  verifiedAt DateTime?

  @@index([status, startedAt])
  @@index([targetId, startedAt])
}

/// Trouble ticket for fault repair: office opens (often from a bad-signal ONU), assigns a
/// technician (Telegram DM), technician starts→resolves, office verifies with an objective
/// before/after signal comparison. Timestamps drive the repair-time (MTTR) reporting.
model Ticket {
  id             Int      @id @default(autoincrement())
  onuId          Int
  onu            Onu      @relation(fields: [onuId], references: [id], onDelete: Cascade)
  oltId          Int
  olt            Olt      @relation(fields: [oltId], references: [id], onDelete: Cascade)
  category       String   // signal_high | offline | pppoe | other
  severity       String?  // warning | critical | null
  title          String
  description    String?
  status         String   @default("open") // open | assigned | in_progress | resolved | verified | reopened
  openedById     Int?
  openedBy       User?    @relation("TicketOpenedBy", fields: [openedById], references: [id], onDelete: SetNull)
  assignedToId   Int?
  assignedTo     User?    @relation("TicketAssignedTo", fields: [assignedToId], references: [id], onDelete: SetNull)
  resolutionNote String?
  rxAtOpen       Float?   // ONU Rx dBm snapshot when opened (objective before-value)
  oltRxAtOpen    Float?
  rxAtVerify     Float?   // ONU Rx dBm at office verification (after-value)
  openedAt       DateTime @default(now())
  assignedAt     DateTime?
  startedAt      DateTime? // repair clock starts
  resolvedAt     DateTime? // repair clock stops (technician done)
  verifiedAt     DateTime?

  @@index([oltId, status])
  @@index([assignedToId, status])
  @@index([status])
}

model AuditLog {
  id        BigInt   @id @default(autoincrement())
  userId    Int?
  action    String // authorize_onu | set_pppoe | wifi_update | add_olt ...
  oltId     Int?
  olt       Olt?     @relation(fields: [oltId], references: [id], onDelete: SetNull)
  ponPort   String?
  payload   Json? // sanitized (no plaintext passwords)
  result    String? // success | error
  createdAt DateTime @default(now())

  @@index([createdAt])
  @@index([action])
}

model Job {
  id        String   @id // matches BullMQ job id
  type      String
  status    String   @default("queued") // queued | active | done | failed
  oltId     Int?
  olt       Olt?     @relation(fields: [oltId], references: [id], onDelete: SetNull)
  ponPort   String?
  payload   Json?
  output    String? // raw device output (troubleshooting)
  error     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Baileys (WhatsApp Web multi-device) auth store. One row for "creds", one per
// signal key ("key:<type>:<id>"). `data` is AES-GCM encrypted BufferJSON — this is
// a full WhatsApp session, so it must never be stored in plaintext.
model WhatsappAuth {
  id        String   @id
  data      String
  updatedAt DateTime @updatedAt
}
