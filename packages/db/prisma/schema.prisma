generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Olt {
  id          Int       @id @default(autoincrement())
  name        String
  ip          String    @unique
  port        Int       @default(23)
  protocol    String    @default("telnet") // telnet | ssh
  username    String
  passwordEnc String // AES-256-GCM encrypted, see @oltflow/core crypto
  enablePasswordEnc String? // AES-256-GCM encrypted privileged/enable password (null = use login password)
  location    String?
  vendor      String    @default("zte")
  model       String? // C300 | C320
  slots       Int[]     @default([4, 15, 17, 19, 20]) // GPON board slots
  eponSlots   Int[]     @default([]) // EPON board slots (ETTO/ETTOK cards) — empty if none, e.g. pure-GPON OLTs
  snmpCommunity String? @default("public")
  snmpVersion   String? @default("2c") // 2c | v3 (v3 not implemented yet)
  snmpPort      Int     @default(161)
  status      String    @default("unknown") // online | offline | unknown
  lastSync    DateTime?
  onus        Onu[]
  uncfgOnus   UncfgOnu[]
  jobs        Job[]
  auditLogs   AuditLog[]
  ponTraffic  PonTraffic[]
  users       User[]    @relation("UserOlts") // support/viewer scoping (empty = all; admin ignores)
  createdAt   DateTime  @default(now())
}

/// Unconfigured (waiting-authorization) ONUs, persisted from each inventory sync so the
/// dashboard/Unconfigured page read a stable DB row instead of a live `show gpon onu uncfg`
/// per page-load. Reconciled every sync tick: present serials are upserted, absent ones
/// removed — so the "waiting authorization" count is always accurate without a Scan button.
model UncfgOnu {
  id        Int      @id @default(autoincrement())
  oltId     Int
  olt       Olt      @relation(fields: [oltId], references: [id], onDelete: Cascade)
  ponPort   String // gpon-olt_1/15/1 (the PON it was detected on)
  serial    String // ONU serial broadcast before authorization
  state     String? // raw uncfg state, e.g. "unknown"
  firstSeen DateTime @default(now())
  lastSeen  DateTime @default(now())

  @@unique([oltId, serial])
  @@index([oltId])
}

model Onu {
  id             Int       @id @default(autoincrement())
  oltId          Int
  olt            Olt       @relation(fields: [oltId], references: [id], onDelete: Cascade)
  ponPort        String // gpon-onu_1/15/1:1
  serial         String?
  name           String?
  type           String?
  state          String? // working | fail | offline ...
  distance       String?
  onlineDuration String?
  vlan           String?
  pppoeUser      String?
  lineProfile    String?
  serviceProfile String?
  mac            String? // MAC learned on the bridge port (the downstream Mikrotik) — RADIUS join key
  mgmtIp         String? // live device IP (route ONU / bridge Mikrotik), filled from RADIUS by the worker
  expiration     DateTime? // client account expiry from RADIUS Manager (rm_users), filled by the worker
  lastSeen       DateTime?
  signals        Signal[]

  @@unique([oltId, ponPort])
  @@index([serial])
  @@index([state])
  @@index([oltId, state]) // dashboard/list rollups: count + groupBy ONUs per OLT by state
}

model Signal {
  id          BigInt   @id @default(autoincrement())
  onuId       Int
  onu         Onu      @relation(fields: [onuId], references: [id], onDelete: Cascade)
  oltRx       Float?
  onuRx       Float?
  oltTx       Float?
  onuTx       Float?
  attenUp     Float?
  attenDown   Float?
  signalLevel String? // good | warning | critical
  recordedAt  DateTime @default(now())

  @@index([onuId, recordedAt])
  @@index([signalLevel, recordedAt]) // dashboard stats: recent warning/critical signals per OLT
}

/// Per-PON-port throughput samples derived from SNMP 32-bit ifInOctets/ifOutOctets
/// (this ZTE firmware leaves the 64-bit HC counters empty). One row per port per poll;
/// the worker computes bps from the octet delta between polls and prunes rows >24h.
/// downBps = traffic to subscribers (PON ifOutOctets), upBps = from subscribers (ifInOctets).
model PonTraffic {
  id         BigInt   @id @default(autoincrement())
  oltId      Int
  olt        Olt      @relation(fields: [oltId], references: [id], onDelete: Cascade)
  ponPort    String // ifName, e.g. gpon_1/15/6
  downBps    Float
  upBps      Float
  recordedAt DateTime @default(now())

  @@index([oltId, recordedAt])
  @@index([oltId, ponPort, recordedAt])
}

model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  name      String?
  passwordH String
  role      String   @default("operator") // admin | operator | viewer
  /// OLTs this user may see/operate. Empty = all (backward compatible, unrestricted);
  /// admins are never scoped. Assign specific OLTs to restrict support to their zone.
  olts      Olt[]    @relation("UserOlts")
  createdAt DateTime @default(now())
}

model AuditLog {
  id        BigInt   @id @default(autoincrement())
  userId    Int?
  action    String // authorize_onu | set_pppoe | wifi_update | add_olt ...
  oltId     Int?
  olt       Olt?     @relation(fields: [oltId], references: [id], onDelete: SetNull)
  ponPort   String?
  payload   Json? // sanitized (no plaintext passwords)
  result    String? // success | error
  createdAt DateTime @default(now())

  @@index([createdAt])
  @@index([action])
}

model Job {
  id        String   @id // matches BullMQ job id
  type      String
  status    String   @default("queued") // queued | active | done | failed
  oltId     Int?
  olt       Olt?     @relation(fields: [oltId], references: [id], onDelete: SetNull)
  ponPort   String?
  payload   Json?
  output    String? // raw device output (troubleshooting)
  error     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
